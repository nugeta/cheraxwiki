---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

const { head } = Astro.locals.starlightRoute;
const { entry } = Astro.locals.starlightRoute;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const siteName = 'Cherax Wiki';
const pageTitle = entry.data.title
	? `${entry.data.title} | ${siteName}`
	: siteName;
const pageDescription =
	entry.data.description ??
	'Fan-made tutorials and guides for the Cherax GTA mod menu.';

const isHome = Astro.url.pathname === '/';

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: siteName,
	url: Astro.site?.toString(),
	description:
		'A fan-made collection of tutorials and guides for the Cherax GTA mod menu - purchasing, customization, Luas, recoveries and more.',
	inLanguage: 'en',
};

const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: siteName,
	url: Astro.site?.toString(),
	logo: new URL('/logo.png', Astro.site).toString(),
};

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'TechArticle',
	headline: entry.data.title,
	description: pageDescription,
	url: canonicalURL.toString(),
	isPartOf: {
		'@type': 'WebSite',
		name: siteName,
		url: Astro.site?.toString(),
	},
};
---

{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}

<link rel="canonical" href={canonicalURL} />
<meta name="theme-color" content="#7c4dff" />

{/* Open Graph (no image — avoids the logo embed preview) */}
<meta property="og:url" content={canonicalURL} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDescription} />

{/* Twitter — text-only summary, no image */}
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={pageDescription} />

{isHome ? (
	<>
		<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
	</>
) : (
	<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
)}

<Analytics />
<SpeedInsights />
